# ============================================
# VOICE STREAMING SETUP - ENVIRONMENT VARIABLES
# ============================================

# OpenRouter API (for AI responses)
OPENROUTER_API_KEY=sk-or-your-key-here

# OpenAI API (for Speech-to-Text - Whisper)
OPENAI_API_KEY=sk-your-key-here

# ElevenLabs API (for Text-to-Speech - Natural Voice)
ELEVENLABS_API_KEY=your-key-here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Default: Rachel voice

# Backend Configuration
VOICE_PORT=4000
BACKEND_URL=http://localhost:5000

# Optional: Google Cloud TTS (Alternative to ElevenLabs)
GOOGLE_TTS_API_KEY=your-key-here

# ============================================
# SETUP INSTRUCTIONS
# ============================================

# 1. Get OpenRouter API Key:
#    → https://openrouter.ai/keys

# 2. Get OpenAI API Key (for Whisper):
#    → https://platform.openai.com/api-keys

# 3. Get ElevenLabs API Key:
#    → https://elevenlabs.io/app/settings
#    → Voice ID: Go to Voice Lab → Copy voice ID

# 4. Install dependencies:
cd backend
npm install ws node-fetch

# 5. Start voice server:
npm run voice-server

# 6. Test:
#    → Open tutor page
#    → Click "PUSH TO TALK" button
#    → Speak: "Hello, can you hear me?"
#    → AI will respond with voice!
